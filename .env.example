
# ── .env.example ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Gemini — free tier: 15 req/min, 1M tokens/month
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# JWT — change this to a strong random string in production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_32_char_random_string

# GCP project ID (for Firestore + Cloud Run)
FIREBASE_PROJECT_ID=your_gcp_project_id

# MOCK=true uses in-memory data (no Firestore needed for local dev)
MOCK=true

# Ops dashboard password (basic protection)
OPS_PASSWORD=admin123