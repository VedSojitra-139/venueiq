{
  "name": "venueiq",
  "version": "1.0.0",
  "description": "AI-powered cricket stadium navigation and crowd management system",
  "main": "src/server.js",
  "engines": { "node": ">=20" },
  "scripts": {
    "start":   "node src/server.js",
    "dev":     "nodemon src/server.js",
    "test":    "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint":    "eslint src tests --ext .js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.3.0",
    "cors":                  "^2.8.5",
    "dotenv":                "^16.3.1",
    "express":               "^4.18.2",
    "express-rate-limit":    "^7.1.5",
    "firebase-admin":        "^12.0.0",
    "helmet":                "^7.1.0",
    "jsonwebtoken":          "^9.0.2",
    "ws":                    "^8.16.0",
    "zod":                   "^3.22.4"
  },
  "devDependencies": {
    "jest":       "^29.7.0",
    "nodemon":    "^3.0.3",
    "supertest":  "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageThreshold": { "global": { "lines": 70 } }
  }
}